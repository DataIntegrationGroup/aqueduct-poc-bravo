# ── FROST (local Docker) ─────────────────────────────────────────────────────
FROST_SERVICE_ROOT_URL=http://localhost:8081/FROST-Server
POSTGRES_DB=sensorthings
POSTGRES_USER=sensorthings
POSTGRES_PASSWORD=changeme

# ── GCS raw zone ──────────────────────────────────────────────────────────────
GCS_BUCKET_NAME=your-bucket-name
# Path to a GCP service account JSON key file.
# Alternatively leave blank and use: gcloud auth application-default login
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── HydroVu API ───────────────────────────────────────────────────────────────
HYDROVU_CLIENT_ID=your-client-id
HYDROVU_CLIENT_SECRET=your-client-secret
# HydroVu OAuth2 token endpoint (public, no need to change)
HYDROVU_TOKEN_URL=https://www.hydrovu.com/public-api/oauth/token
# HydroVu API base URL
HYDROVU_API_BASE_URL=https://www.hydrovu.com/public-api/v1

# ── dlt pipeline ─────────────────────────────────────────────────────────────
DLT_PIPELINE_NAME=pvacd_hydrovu
# GCS path prefix for raw parquet files: gs://<bucket>/<DLT_DATASET_NAME>/
DLT_DATASET_NAME=raw/pvacd
