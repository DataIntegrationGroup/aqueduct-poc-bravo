# Copy this to secrets.toml and fill in real values.
# secrets.toml is in .gitignore — never commit it.

[hydrovu]
client_id     = "your-hydrovu-client-id"
client_secret = "your-hydrovu-client-secret"

[destination.filesystem.credentials]
# Option A: service account JSON key
project_id   = "your-gcp-project-id"
private_key  = "-----BEGIN RSA PRIVATE KEY-----\n..."
client_email = "your-sa@your-project.iam.gserviceaccount.com"

# Option B: if using ADC (gcloud auth application-default login),
# leave this section empty — dlt will pick up ADC automatically.
